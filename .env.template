# ============================================================================
# Agentic Security Lab - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ============================================================================

# IBM Verify Configuration
# -------------------------
# Obtain these from your IBM Verify tenant administrator
IBM_VERIFY_TENANT=your-tenant-name
IBM_VERIFY_OIDC_URL=https://your-tenant-name.verify.ibm.com/oidc/endpoint/default

# Frontend Client (for user SSO authentication via AskHR frontend)
# Create this client in IBM Verify with:
#   - Grant Type: Authorization Code
#   - Access Token Format: JWT
#   - Returns: User access token (subject token)
IBM_VERIFY_FRONTEND_CLIENT_ID=your-frontend-client-id
IBM_VERIFY_FRONTEND_CLIENT_SECRET=your-frontend-client-secret

# Agent Client (for bot identity via client credentials)
# Create this client in IBM Verify with:
#   - Grant Type: Client Credentials
#   - Access Token Format: JWT
#   - Returns: Agent access token (actor token)
IBM_VERIFY_AGENT_CLIENT_ID=your-agent-client-id
IBM_VERIFY_AGENT_CLIENT_SECRET=your-agent-client-secret

# Tool/Exchange Client (for token exchange in Langflow)
# Create this client in IBM Verify with:
#   - Grant Type: Token Exchange
#   - Access Token Format: JWT
#   - Introspect Endpoint: Configure 'act' claim mapping
#   - Returns: Delegated token with 'act' claim for Vault
# See docs/IBM_VERIFY_THREE_CLIENT_SETUP.md for detailed setup instructions
IBM_VERIFY_TOOL_CLIENT_ID=your-tool-client-id
IBM_VERIFY_TOOL_CLIENT_SECRET=your-tool-client-secret

# Vault Configuration
# -------------------
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_NAMESPACE=

# PostgreSQL Configuration (Employee Database)
# --------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=employee_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Langflow PostgreSQL Configuration
# ---------------------------------
LANGFLOW_POSTGRES_DB=langflow
LANGFLOW_POSTGRES_USER=langflow
LANGFLOW_POSTGRES_PASSWORD=langflow

# Langflow Configuration
# ----------------------
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=admin
LANGFLOW_AUTO_LOGIN=false

# Flask Secret Key (for session management)
# -----------------------------------------
# Generate a secure random key using: python -c "import secrets; print(secrets.token_hex(32))"
# Or run: ./generate-secret-key.sh
FLASK_SECRET_KEY=your-generated-secret-key-here

# AskHR Frontend Configuration
# ----------------------------
# IBM Verify OAuth Configuration for Frontend
REACT_APP_IBM_VERIFY_CLIENT_ID=${IBM_VERIFY_FRONTEND_CLIENT_ID}
REACT_APP_IBM_VERIFY_ISSUER=${IBM_VERIFY_OIDC_URL}
REACT_APP_IBM_VERIFY_REDIRECT_URI=http://localhost:3000/callback
IBM_VERIFY_REDIRECT_URI=http://localhost:3000/callback

# Langflow API Configuration for Frontend
REACT_APP_LANGFLOW_API_URL=http://localhost:7860

# Langflow Chat Widget Configuration
# -----------------------------------
# API key for Langflow embedded chat widget
# Obtain from Langflow UI: Settings > API Keys
REACT_APP_LANGFLOW_API_KEY=your-langflow-api-key-here

# Langflow host URL (where Langflow is running)
REACT_APP_LANGFLOW_HOST_URL=http://localhost:7860

# Langflow flow ID for the AskHR chat widget
# Get this from your deployed flow in Langflow UI
REACT_APP_LANGFLOW_FLOW_ID=6158c23c-7d05-49db-ba6e-0b3304f7df2a

# Langflow component ID for tweaks (Vault Credentials Tool)
# This is the component ID in your flow that receives the JWT token
REACT_APP_LANGFLOW_COMPONENT_ID=vault_credentials_tool-okuBC

# Application Configuration
REACT_APP_NAME=AskHR
REACT_APP_VERSION=1.0.0

# Feature Flags
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_ANALYTICS=false

# Lab Configuration
# -----------------
# Set to 'development' or 'production'
ENVIRONMENT=development

# Logging Level
LOG_LEVEL=INFO